---
import ChatDemo from "./_components/ChatDemo";
import Layout from "@/layouts/RootLayout.astro";
---

<Layout
  title="CSS interpolate-size Demo | Smooth Auto Height Animations"
  description="A live demonstration of the CSS interpolate-size property. See how to smoothly animate height: auto and other intrinsic sizes without JavaScript."
>
  <div class="max-w-5xl mx-auto space-y-10">
    <header class="text-center space-y-5">
      <h1
        class="text-4xl md:text-5xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100"
      >
        CSS <code
          class="text-purple-600 bg-purple-50 dark:text-purple-300 dark:bg-purple-900/50 px-2 py-1 rounded-lg text-3xl md:text-4xl"
          >interpolate-size
        </code>
      </h1>
      <p
        class="text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto text-lg"
      >
        A demonstration of the new CSS property that enables smooth transitions
        to and from intrinsic sizes like <code>height: auto</code>.
      </p>
      <div
        class="bg-amber-50 border border-amber-200 text-amber-800 dark:bg-amber-900/40 dark:border-amber-700 dark:text-amber-200 px-5 py-4 rounded-xl text-sm inline-flex items-start text-left max-w-2xl shadow-sm"
      >
        <svg
          class="w-5 h-5 mr-3 shrink-0 mt-0.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path></svg
        >
        <div>
          <strong class="block mb-1">Browser Support Notice</strong>
          This feature requires Chrome 129+, Edge 129+, or a browser with <code
            >interpolate-size: allow-keywords</code
          > support. In unsupported browsers, both examples will snap.
        </div>
      </div>
    </header>

    <section
      class="grid md:grid-cols-2 gap-8 items-start max-w-5xl mx-auto"
      aria-label="Interactive Demos"
    >
      <ChatDemo useInterpolateSize={false} client:idle />
      <ChatDemo useInterpolateSize={true} client:idle />
    </section>
  </div>
  <style is:inline>
    .chat-demo-interpolate-size {
      interpolate-size: allow-keywords;
    }

    .chat-demo-message-container {
      height: 0;
      overflow: hidden;
      transition: height 0.5s cubic-bezier(0.4, 0, 0.2, 1);

      &.open {
        height: auto;
      }
    }
  </style>
</Layout>
